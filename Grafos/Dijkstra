#include <bits/stdc++.h>
#define int long long
using namespace std;

const int MAXN = 1e5 + 10;
const int INF = 1e18; // INF seguro para long long

vector<pair<int,int>> adj[MAXN];
int dist[MAXN];

// Retorna as distâncias a partir de um vértice 'start'
void dijkstra(int start, int n) {
    // 1. Inicializa as distâncias com infinito
    for(int i = 0; i <= n; i++) {
        dist[i] = INF;
    }
    
    // priority_queue guarda {-distancia, vertice}
    priority_queue<pair<int,int>> pq;
    
    dist[start] = 0;
    pq.push({0, start});

    while(!pq.empty()) {
        int d = -pq.top().first; 
        int u = pq.top().second;
        pq.pop();

        // Otimização: se achou um caminho pior do que o já salvo, ignora
        if(d > dist[u]) continue;

        for(auto edge : adj[u]) {
            int v = edge.first;
            int peso = edge.second;

            // Lógica do Dijkstra de Soma
            if(dist[u] + peso < dist[v]) {
                dist[v] = dist[u] + peso;
                pq.push({-dist[v], v}); 
            }
        }
    }
}

int32_t main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m;
    if (!(cin >> n >> m)) return 0;

    for(int i = 0; i < m; i++) {
        int u, v, w;
        cin >> u >> v >> w;
        adj[u].push_back({v, w});
        // Se o grafo for bidirecional, descomente a linha abaixo:
        // adj[v].push_back({u, w});
    }

    int origem = 1; // Nó de onde o Dijkstra vai começar
    dijkstra(origem, n);

    // Exemplo de como imprimir a distância até o nó 'n'
    if(dist[n] == INF) cout << -1 << "\n";
    else cout << dist[n] << "\n";

    return 0;
}

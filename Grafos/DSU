#include <bits/stdc++.h>
#define int long long
using namespace std;

const int MAXN = 1e5 + 10;

// Variáveis globais do DSU
int pai[MAXN];
int sz[MAXN];

// Estrutura para guardar as arestas
// Usamos tuple {peso, u, v} porque o C++ já ordena tuple automaticamente pelo primeiro elemento!
vector<tuple<int, int, int>> arestas;

// 1. Inicializa o DSU
void init(int n) {
    for(int i = 0; i <= n; i++) {
        pai[i] = i;  // Cada um é seu próprio pai no começo
        sz[i] = 1;   // Tamanho inicial é 1
    }
}

// 2. Acha a raiz (com Path Compression)
int find(int v) {
    if(pai[v] == v) return v;
    return pai[v] = find(pai[v]);
}

// 3. Une dois conjuntos (com Union by Size)
// Troquei o nome de 'un' para 'join' para evitar confusão com palavras reservadas do C++
void join(int a, int b) {
    a = find(a);
    b = find(b);

    if(a == b) return;

    // Garante que 'a' é a maior árvore
    if(sz[b] > sz[a]) swap(a, b);

    pai[b] = a;
    sz[a] += sz[b];
}

int32_t main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m;
    if (!(cin >> n >> m)) return 0;

    // Inicializa os pais e os tamanhos
    init(n);

    for(int i = 0; i < m; i++) {
        int u, v, peso;
        cin >> u >> v >> peso;
        arestas.push_back({peso, u, v});
    }

    // O pulo do gato do Kruskal: ordenar as arestas do menor pro maior peso
    sort(arestas.begin(), arestas.end());

    int custo_mst = 0;
    int arestas_usadas = 0;

    for(auto [peso, u, v] : arestas) {
        // Se u e v não estão no mesmo conjunto, não formam ciclo!
        if(find(u) != find(v)) {
            join(u, v);
            custo_mst += peso;
            arestas_usadas++;
        }
    }

    // Verifica se todos os nós foram conectados (se o grafo original for conexo)
    if(arestas_usadas == n - 1) {
        cout << custo_mst << "\n";
    } else {
        cout << "IMPOSSIBLE\n"; // Caso o grafo tenha componentes desconexos
    }

    return 0;
}

#include <bits/stdc++.h>
#define int long long
using namespace std;

const int MAXN = 1e6 + 10;
vector<int> adj[MAXN];

// 0 = Nao visitado, 1 = Explorando (na pilha atual), 2 = Totalmente visitado (fechado)
int cor[MAXN]; 
int pai[MAXN];

int inicio_ciclo = -1;
int fim_ciclo = -1;

bool dfs_ciclo_direcionado(int u) {
    cor[u] = 1; // Pinta de cinza (entrou na pilha)

    for(int v : adj[u]) {
        if(cor[v] == 0) { // Se não foi visitado, mergulha nele
            pai[v] = u;
            if(dfs_ciclo_direcionado(v)) return true;
        } 
        else if(cor[v] == 1) { // Opa! Bateu no próprio rastro. É CICLO!
            inicio_ciclo = v;
            fim_ciclo = u;
            return true;
        }
        // Se cor[v] == 2, a gente simplesmente ignora, não é ciclo.
    }

    cor[u] = 2; // Pinta de preto (fechou, já olhamos tudo a partir daqui)
    return false;
}

// Função para imprimir o ciclo (igualzinha à do grafo indirecionado)
void imprimir_ciclo() {
    if(inicio_ciclo == -1) {
        cout << "IMPOSSIBLE\n"; // Padrao do CSES
        return;
    }

    vector<int> ciclo;
    ciclo.push_back(inicio_ciclo);
    for(int v = fim_ciclo; v != inicio_ciclo; v = pai[v]) {
        ciclo.push_back(v);
    }
    ciclo.push_back(inicio_ciclo);
    
    // Como voltamos pelos pais, a ordem fica de trás pra frente
    reverse(ciclo.begin(), ciclo.end()); 

    cout << ciclo.size() << "\n";
    for(int v : ciclo) cout << v << " ";
    cout << "\n";
}

int32_t main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, m;
    if(!(cin >> n >> m)) return 0;

    for(int i = 0; i < m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v); // Direcionado: só u -> v
    }

    // Como o grafo pode ser desconexo, precisamos testar todos os nós
    bool achou = false;
    for(int i = 1; i <= n; i++) {
        if(cor[i] == 0) {
            if(dfs_ciclo_direcionado(i)) {
                achou = true;
                break;
            }
        }
    }

    if(achou) {
        imprimir_ciclo();
    } else {
        cout << "IMPOSSIBLE\n";
    }

    return 0;
}

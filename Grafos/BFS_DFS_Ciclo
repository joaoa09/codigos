#include <bits/stdc++.h>
#define int long long
using namespace std;

const int MAXN = 1e6 + 10;
const int INF = 1e18; // Adaptado para o padrão long long

vector<int> adj[MAXN];

// ====================================================================
// 1. BFS Clássica (Menor Caminho em grafos sem peso)
// ====================================================================
vector<int> dist_bfs(MAXN, INF);

void bfs(int start) {
    queue<int> q;
    q.push(start);
    dist_bfs[start] = 0;

    while(!q.empty()){
        int u = q.front();
        q.pop();

        for(auto v : adj[u]){
            // Se achou um caminho mais curto, atualiza e joga na fila
            if(dist_bfs[u] + 1 < dist_bfs[v]){
                dist_bfs[v] = dist_bfs[u] + 1;
                q.push(v);
            }
        }
    }
}

// ====================================================================
// 2. DFS Clássica (Travessia, Componentes Conexos e Flood Fill)
// ====================================================================
vector<bool> vis(MAXN, false);

void dfs(int u) {
    vis[u] = true; // Marca que já passou por aqui

    for(auto v : adj[u]){
        if(!vis[v]){
            dfs(v); // Mergulha no vizinho
        }
    }
}

// ====================================================================
// 3. DFS - Detector de Ciclos (Grafo NÃO Direcionado)
// ====================================================================
vector<bool> vis_ciclo(MAXN, false);
vector<int> pai_ciclo(MAXN, -1);
int inicio_ciclo = -1, fim_ciclo = -1;

// Retorna true se achar ciclo. O 'p' é o nó de onde viemos (pai).
bool dfs_ciclo_indirecionado(int u, int p) {
    vis_ciclo[u] = true;
    pai_ciclo[u] = p;

    for(auto v : adj[u]) {
        if(v == p) continue; // Ignora a aresta de onde acabamos de vir

        if(vis_ciclo[v]) {
            // Achamos o ciclo!
            inicio_ciclo = v;
            fim_ciclo = u;
            return true;
        }

        if(dfs_ciclo_indirecionado(v, u)) {
            return true;
        }
    }
    return false;
}

// ====================================================================
// Função Auxiliar: Reconstruir o ciclo achado pela DFS
// ====================================================================
void imprimir_ciclo() {
    if(inicio_ciclo == -1) {
        cout << "Nao tem ciclo\n";
        return;
    }

    vector<int> ciclo;
    ciclo.push_back(inicio_ciclo);
    for(int v = fim_ciclo; v != inicio_ciclo; v = pai_ciclo[v]) {
        ciclo.push_back(v);
    }
    ciclo.push_back(inicio_ciclo);

    cout << "Ciclo achado (tamanho " << ciclo.size() << "):\n";
    for(int v : ciclo) cout << v << " ";
    cout << "\n";
}

